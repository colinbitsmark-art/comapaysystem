# Server (dotenv loads from project root)
PORT=4000
DATA_DIR=./server/data

# Required in production — used to sign login JWTs
JWT_SECRET=change-this-to-a-long-random-string

# First admin (only used when the database has zero users)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=Admin

# Optional: restrict CORS (comma-separated origins). Omit for same-origin SPA.
# CORS_ORIGINS=https://your-app.railway.app

# Internal cron auth for wallet auto-refresh (server → itself)
INTERNAL_CRON_SECRET=change-this-internal-secret

# Shared reference rates (Railway Postgres) — reference DATABASE_URL on each web service
REFERENCE_RATES_CONFIG_ID=default

# Telegram (in-app Bot API — no external ordersystem-telegram-bot service)
ENABLE_TELEGRAM_NOTIFICATIONS=true
TELEGRAM_BOT_TOKEN=
# Rates group: Send to Telegram button + default notification target
TELEGRAM_RATES_CHAT_ID=
# Optional separate group for order notifications (defaults to TELEGRAM_RATES_CHAT_ID)
# TELEGRAM_NOTIFICATION_CHAT_ID=
# Webhook for /command1, /help, /chatid (HTTPS required; Telegram → this app)
# Full URL or public app base (https://your-app.railway.app)
TELEGRAM_WEBHOOK_URL=
# Or: PUBLIC_APP_URL=https://your-app.railway.app
# Secret verified via X-Telegram-Bot-Api-Secret-Token header
TELEGRAM_WEBHOOK_SECRET=
# Optional: comma-separated chat ids allowed to run commands
# TELEGRAM_ALLOWED_CHAT_IDS=-100xxxxxxxxxx

# Bot HTTP API (optional — external tools only; not used by in-app Telegram)
BOT_API_KEY=

# Resend — password reset emails (https://resend.com)
RESEND_API_KEY=
MAIL_FROM="Operations Console <noreply@yourdomain.com>"
# Optional display name in email subjects (defaults to Operations Console)
# APP_NAME=Operations Console
