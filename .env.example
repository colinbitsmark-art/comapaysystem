# Server (dotenv loads from project root)
PORT=4000
DATA_DIR=./server/data

# Shared reference rates (Railway Postgres) — reference DATABASE_URL on each web service
REFERENCE_RATES_CONFIG_ID=default

# Telegram rate sheet (Option A — external bot receives webhook)
ENABLE_TELEGRAM_NOTIFICATIONS=true
TELEGRAM_BOT_WEBHOOK_URL=http://localhost:3001/webhook/notification
# Optional dedicated URL; default replaces /notification with /rate-sheet
# TELEGRAM_BOT_RATE_SHEET_WEBHOOK_URL=http://localhost:3001/webhook/rate-sheet
TELEGRAM_BOT_WEBHOOK_SECRET=your-secret-key-here

# Bot API (for /command1 in PRICE7GGBOT)
BOT_API_KEY=
